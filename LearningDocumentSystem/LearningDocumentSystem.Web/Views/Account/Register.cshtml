@model LearningDocumentSystem.Web.ViewModels.RegisterStudentViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Đăng ký sinh viên — LDS System</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="~/css/site.css"/>
</head>
<body class="auth-body">

<div class="auth-container">
    <div class="auth-right">
        <div class="auth-card auth-card--wide">
            <div class="auth-card-brand">
                <div class="auth-logo">
                    <i class="bi bi-person-plus-fill"></i>
                </div>
                <h1 class="auth-title">LDS System</h1>
                <p class="auth-subtitle">Đăng ký sinh viên</p>
            </div>

            <div class="auth-card-header">
                <h2>Tạo tài khoản</h2>
                <p>Nhập MSSV và thông tin cá nhân theo danh sách nhà trường.</p>
            </div>

            <form asp-action="Register" method="post" id="registerForm">
                @Html.AntiForgeryToken()

                @{
                    var summaryErrors = ViewData.ModelState.Values
                        .SelectMany(v => v.Errors)
                        .Select(e => e.ErrorMessage)
                        .ToList();
                }
                @if (summaryErrors.Any())
                {
                    <div class="alert alert-danger d-flex align-items-center mb-3">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <span>@summaryErrors.First()</span>
                    </div>
                }

                <div class="form-group-custom mb-3">
                    <label class="form-label-custom" asp-for="StudentCode">
                        <i class="bi bi-badge-id me-1"></i> MSSV
                    </label>
                    <input asp-for="StudentCode" class="form-control form-control-custom"
                           placeholder="VD: SE123456" autocomplete="username"/>
                    <span asp-validation-for="StudentCode" class="text-danger small"></span>
                </div>

                <div class="form-group-custom mb-3">
                    <label class="form-label-custom" asp-for="FullName">
                        <i class="bi bi-person-fill me-1"></i> Họ và tên
                    </label>
                    <input asp-for="FullName" class="form-control form-control-custom"
                           placeholder="Nhập đúng họ tên trong danh sách trường"/>
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="form-group-custom mb-3">
                    <label class="form-label-custom" asp-for="Password">
                        <i class="bi bi-lock-fill me-1"></i> Mật khẩu
                    </label>
                    <div class="input-password-wrap">
                        <input asp-for="Password" class="form-control form-control-custom"
                               placeholder="Ít nhất 6 ký tự, gồm chữ và số"/>
                        <button type="button" class="btn-toggle-pwd" onclick="togglePassword('Password', 'pwdIcon1')">
                            <i class="bi bi-eye" id="pwdIcon1"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="form-group-custom mb-4">
                    <label class="form-label-custom" asp-for="ConfirmPassword">
                        <i class="bi bi-lock-fill me-1"></i> Xác nhận mật khẩu
                    </label>
                    <div class="input-password-wrap">
                        <input asp-for="ConfirmPassword" class="form-control form-control-custom"
                               placeholder="Nhập lại mật khẩu"/>
                        <button type="button" class="btn-toggle-pwd" onclick="togglePassword('ConfirmPassword', 'pwdIcon2')">
                            <i class="bi bi-eye" id="pwdIcon2"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn-login" id="btnRegister">
                    <span class="btn-text"><i class="bi bi-person-check-fill me-2"></i>Đăng ký</span>
                    <span class="btn-loading d-none">
                        <span class="spinner-border spinner-border-sm me-2"></span> Đang xử lý...
                    </span>
                </button>
            </form>

            <div class="auth-footer-link">
                Đã có tài khoản? <a asp-action="Login">Đăng nhập</a>
            </div>

            <div class="demo-credentials mt-4">
                <p class="demo-title"><i class="bi bi-info-circle me-1"></i> MSSV mẫu để thử đăng ký:</p>
                <div class="demo-accounts">
                    <span class="demo-acc" onclick="fillRegister('SE654321','Le Thi B')">
                        <i class="bi bi-person-fill text-success"></i> SE654321 / Le Thi B
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
<script>
    function togglePassword(fieldId, iconId) {
        const pwd = document.getElementById(fieldId);
        const icon = document.getElementById(iconId);
        if (pwd.type === 'password') {
            pwd.type = 'text';
            icon.className = 'bi bi-eye-slash';
        } else {
            pwd.type = 'password';
            icon.className = 'bi bi-eye';
        }
    }

    function fillRegister(code, name) {
        document.getElementById('StudentCode').value = code;
        document.getElementById('FullName').value = name;
    }

    document.getElementById('registerForm').addEventListener('submit', function () {
        document.querySelector('.btn-text').classList.add('d-none');
        document.querySelector('.btn-loading').classList.remove('d-none');
    });
</script>
</body>
</html>
