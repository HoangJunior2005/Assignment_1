@model LearningDocumentSystem.Web.ViewModels.ChapterListViewModel
@{
    ViewData["Title"] = "Chương học";
}

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-collection-fill me-2"></i>Chương học</h1>
        <p class="page-subtitle">Quản lý các chương học trong môn học</p>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
    {
        <a asp-action="Create" class="btn btn-primary btn-action">
            <i class="bi bi-plus-circle me-2"></i>Thêm chương
        </a>
    }
</div>

<!-- Filter by Subject -->
<div class="card-custom mb-4">
    <div class="card-custom-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label small fw-semibold">Lọc theo môn học</label>
                <select name="subjectId" class="form-select" onchange="this.form.submit()">
                    <option value="">— Tất cả môn học —</option>
                    @foreach (var s in Model.Subjects)
                    {
                        <option value="@s.SubjectID" selected="@(Model.SelectedSubjectId == s.SubjectID)">
                            [@s.SubjectCode] @s.SubjectName
                        </option>
                    }
                </select>
            </div>
        </form>
    </div>
</div>

<div class="card-custom">
    <div class="card-custom-body p-0">
        @if (!Model.Chapters.Any())
        {
            <div class="empty-state py-5">
                <i class="bi bi-collection"></i>
                <p>Chưa có chương học nào</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover table-clean mb-0">
                    <thead>
                        <tr>
                            <th>STT</th>
                            <th>Tên chương</th>
                            <th>Môn học</th>
                            <th>Số tài liệu</th>
                            @if (User.IsInRole("Admin") || User.IsInRole("Teacher")) { <th class="text-end">Thao tác</th> }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model.Chapters.OrderBy(x => x.ChapterNumber))
                        {
                            <tr>
                                <td>
                                    <span class="badge bg-primary-subtle text-primary border">
                                        Chương @c.ChapterNumber
                                    </span>
                                </td>
                                <td class="fw-semibold">@c.ChapterName</td>
                                <td class="text-muted">@c.SubjectName</td>
                                <td>
                                    <a asp-controller="Document" asp-action="Index"
                                       asp-route-chapterId="@c.ChapterID"
                                       class="badge bg-secondary-subtle text-secondary border text-decoration-none">
                                        <i class="bi bi-file-earmark me-1"></i>@c.DocumentCount tài liệu
                                    </a>
                                </td>
                                @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
                                {
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="Edit" asp-route-id="@c.ChapterID"
                                               class="btn btn-outline-warning">
                                                <i class="bi bi-pencil-fill"></i>
                                            </a>
                                            <button type="button" class="btn btn-outline-danger"
                                                    onclick="confirmDelete(@c.ChapterID, '@c.ChapterName')">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-0 bg-danger text-white">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle-fill me-2"></i>Xác nhận xóa</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body py-4">
                <p>Xóa chương: <strong class="text-danger" id="delName"></strong>?</p>
            </div>
            <div class="modal-footer border-0">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <form id="delForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash-fill me-1"></i>Xóa</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function confirmDelete(id, name) {
        document.getElementById('delName').textContent = name;
        document.getElementById('delForm').action = '/Chapter/Delete/' + id;
        new bootstrap.Modal(document.getElementById('deleteModal')).show();
    }
</script>
}
