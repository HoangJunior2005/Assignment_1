@model LearningDocumentSystem.Web.ViewModels.ChapterFormViewModel
@{
    bool isEdit = Model.ChapterID > 0;
    ViewData["Title"] = isEdit ? "Sửa chương học" : "Thêm chương học";
}

<div class="page-header">
    <h1 class="page-title">
        <i class="bi bi-@(isEdit ? "pencil-square" : "plus-circle-fill") me-2"></i>
        @ViewData["Title"]
    </h1>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card-custom">
            <div class="card-custom-body">
                <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
                    @Html.AntiForgeryToken()
                    @if (isEdit) { <input type="hidden" asp-for="ChapterID"/> }

                    <div class="mb-4">
                        <label asp-for="SubjectID" class="form-label fw-semibold">Môn học</label>
                        <select asp-for="SubjectID" class="form-select form-select-lg">
                            <option value="">— Chọn môn học —</option>
                            @foreach (var s in Model.Subjects)
                            {
                                <option value="@s.SubjectID">
                                    [@s.SubjectCode] @s.SubjectName
                                </option>
                            }
                        </select>
                        <span asp-validation-for="SubjectID" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ChapterNumber" class="form-label fw-semibold"></label>
                        <input asp-for="ChapterNumber" type="number" min="1" max="100"
                               class="form-control form-control-lg" placeholder="VD: 1"/>
                        <span asp-validation-for="ChapterNumber" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ChapterName" class="form-label fw-semibold"></label>
                        <input asp-for="ChapterName" class="form-control form-control-lg"
                               placeholder="VD: Tổng quan về biến và kiểu dữ liệu"/>
                        <span asp-validation-for="ChapterName" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-@(isEdit ? "save" : "plus-circle") me-1"></i>
                            @(isEdit ? "Cập nhật" : "Tạo chương")
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
