@using LearningDocumentSystem.Business.DTOs
@{
    ViewData["Title"] = "Hỏi đáp AI";
    var subjects = ViewBag.Subjects as IEnumerable<SubjectDto> ?? Enumerable.Empty<SubjectDto>();
}

<!-- Custom Styles for Premium Chat Interface -->
<style>
    .chat-container {
        height: 75vh;
        display: flex;
        gap: 20px;
    }
    
    .chat-sidebar {
        width: 320px;
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }
    
    .chat-main {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 16px;
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.08);
        overflow: hidden;
    }
    
    .chat-header {
        padding: 16px 24px;
        background: linear-gradient(135deg, #4f46e5 0%, #3b82f6 100%);
        color: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .chat-header-title h5 {
        margin: 0;
        font-weight: 700;
        letter-spacing: -0.5px;
    }
    
    .chat-header-status {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.8rem;
        background: rgba(255, 255, 255, 0.15);
        padding: 4px 12px;
        border-radius: 20px;
    }
    
    .status-dot {
        width: 8px;
        height: 8px;
        background-color: #10b981;
        border-radius: 50%;
        display: inline-block;
        box-shadow: 0 0 8px #10b981;
        animation: pulse 2s infinite;
    }
    
    @@keyframes pulse {
        0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7); }
        70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }
        100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
    }
    
    .chat-messages {
        flex-grow: 1;
        padding: 24px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 20px;
        scroll-behavior: smooth;
    }
    
    .message {
        display: flex;
        gap: 12px;
        max-width: 80%;
        animation: fadeIn 0.3s ease;
    }
    
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    .message.user {
        align-self: flex-end;
        flex-direction: row-reverse;
    }
    
    .message.assistant {
        align-self: flex-start;
    }
    
    .message-avatar {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        flex-shrink: 0;
    }
    
    .message.user .message-avatar {
        background: #4f46e5;
        color: white;
    }
    
    .message.assistant .message-avatar {
        background: #e2e8f0;
        color: #4f46e5;
        border: 1px solid rgba(0,0,0,0.05);
    }
    
    .message-content {
        padding: 12px 18px;
        border-radius: 14px;
        font-size: 0.95rem;
        line-height: 1.5;
        position: relative;
    }
    
    .message.user .message-content {
        background: #4f46e5;
        color: white;
        border-top-right-radius: 2px;
    }
    
    .message.assistant .message-content {
        background: white;
        color: #1e293b;
        border-top-left-radius: 2px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        border: 1px solid rgba(0,0,0,0.05);
    }
    
    .message-sources {
        margin-top: 10px;
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        font-size: 0.8rem;
    }
    
    .source-tag {
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        color: #475569;
        padding: 4px 10px;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 4px;
    }
    
    .source-tag:hover {
        background: #e2e8f0;
        color: #1e293b;
        transform: translateY(-1px);
    }
    
    .source-score {
        background: #3b82f6;
        color: white;
        font-weight: 700;
        padding: 1px 4px;
        border-radius: 4px;
        font-size: 0.7rem;
    }
    
    .chat-input-area {
        padding: 16px 24px;
        background: white;
        border-top: 1px solid rgba(0,0,0,0.05);
    }
    
    .chat-input-wrapper {
        display: flex;
        gap: 12px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 24px;
        padding: 4px 6px 4px 16px;
        align-items: center;
        transition: all 0.3s;
    }
    
    .chat-input-wrapper:focus-within {
        border-color: #4f46e5;
        box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
        background: white;
    }
    
    .chat-input {
        flex-grow: 1;
        border: none;
        background: transparent;
        padding: 8px 0;
        font-size: 0.95rem;
        color: #1e293b;
        outline: none;
    }
    
    .btn-send {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #4f46e5;
        color: white;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
    }
    
    .btn-send:hover {
        background: #3730a3;
        transform: scale(1.05);
    }
    
    .btn-send:disabled {
        background: #cbd5e1;
        cursor: not-allowed;
        transform: none;
    }
    
    /* Loading thinking dots */
    .thinking {
        display: flex;
        gap: 4px;
        padding: 8px 10px;
        align-items: center;
    }
    
    .dot {
        width: 8px;
        height: 8px;
        background: #94a3b8;
        border-radius: 50%;
        animation: bounce 1.4s infinite ease-in-out both;
    }
    
    .dot:nth-child(1) { animation-delay: -0.32s; }
    .dot:nth-child(2) { animation-delay: -0.16s; }
    
    @@keyframes bounce {
        0%, 80%, 100% { transform: scale(0); }
        40% { transform: scale(1); }
    }

    /* Message markdown styling */
    .message-content p { margin-bottom: 8px; }
    .message-content p:last-child { margin-bottom: 0; }
    .message-content code {
        background: rgba(0,0,0,0.05);
        padding: 2px 4px;
        border-radius: 4px;
        font-family: monospace;
        font-size: 0.9em;
    }
    .message-content ul, .message-content ol {
        margin-bottom: 8px;
        padding-left: 20px;
    }
    .hover-white:hover {
        color: #ffffff !important;
    }

    /* Chat lock overlay */
    .chat-lock-overlay {
        position: absolute;
        inset: 0;
        z-index: 10;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 16px;
        background: rgba(255, 255, 255, 0.82);
        backdrop-filter: blur(6px);
        border-radius: 16px;
        transition: opacity 0.35s ease, visibility 0.35s ease;
        opacity: 1;
        visibility: visible;
    }
    .chat-lock-overlay.hidden {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
    }
    .chat-lock-icon {
        width: 68px;
        height: 68px;
        border-radius: 50%;
        background: linear-gradient(135deg, #4f46e5 0%, #3b82f6 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 8px 24px rgba(79, 70, 229, 0.35);
        animation: lockPulse 2.5s ease-in-out infinite;
    }
    @@keyframes lockPulse {
        0%, 100% { box-shadow: 0 8px 24px rgba(79, 70, 229, 0.35); transform: scale(1); }
        50% { box-shadow: 0 8px 36px rgba(79, 70, 229, 0.55); transform: scale(1.06); }
    }
    .chat-lock-icon i {
        font-size: 1.8rem;
        color: white;
    }
    .chat-lock-text {
        text-align: center;
        max-width: 280px;
    }
    .chat-lock-text h6 {
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 6px;
        font-size: 1rem;
    }
    .chat-lock-text p {
        color: #64748b;
        font-size: 0.875rem;
        margin: 0;
        line-height: 1.5;
    }
    .chat-main {
        position: relative;
    }
</style>

<div class="page-header mb-3">
    <div>
        <h1 class="page-title"><i class="bi bi-robot me-2"></i>Hỏi đáp AI</h1>
        <p class="page-subtitle">Hỏi đáp thông minh dựa trên tài liệu học tập của bạn</p>
    </div>
</div>

<div class="chat-container">
    
    <!-- LEFT SIDEBAR: FILTERS -->
    <div class="chat-sidebar">
        <div class="card-custom">
            <div class="card-custom-header">
                <h5><i class="bi bi-sliders me-2"></i>Phạm vi tài liệu</h5>
            </div>
            <div class="card-custom-body">
                <!-- Subject selection -->
                <div class="mb-3">
                    <label class="form-label small fw-semibold">Môn học</label>
                    <select class="form-select" id="chatSubjectSelect" onchange="loadChatChapters(this.value)">
                        <option value="">— Tất cả môn học —</option>
                        @foreach (var s in subjects)
                        {
                            <option value="@s.SubjectID">[@s.SubjectCode] @s.SubjectName</option>
                        }
                    </select>
                </div>
                
                <!-- Chapter selection -->
                <div class="mb-4">
                    <label class="form-label small fw-semibold">Chương học</label>
                    <select class="form-select" id="chatChapterSelect" disabled>
                        <option value="">— Tất cả chương —</option>
                    </select>
                </div>
                
                <button type="button" class="btn btn-outline-secondary w-100" onclick="resetChatFilters()">
                    <i class="bi bi-arrow-counterclockwise me-1"></i>Xóa bộ lọc
                </button>
            </div>
        </div>
        
        <!-- Helpful Tips -->
        <div class="card-custom">
            <div class="card-custom-header">
                <h6><i class="bi bi-lightbulb me-2"></i>Mẹo đặt câu hỏi</h6>
            </div>
            <div class="card-custom-body text-muted small">
                <ul class="ps-3 mb-0">
                    <li class="mb-2">Chọn đúng môn học để AI tìm kiếm phân cảnh tài liệu chính xác nhất.</li>
                    <li class="mb-2">Đặt câu hỏi cụ thể, bám sát các khái niệm, định nghĩa trong bài giảng.</li>
                    <li>Sử dụng các từ khóa như: "định nghĩa", "phân biệt", "các bước triển khai".</li>
                </ul>
            </div>
        </div>
    </div>
    
    <!-- RIGHT MAIN: CHATBOX -->
    <div class="chat-main">

        <!-- Lock overlay: shown until user picks a subject -->
        <div class="chat-lock-overlay" id="chatLockOverlay">
            <div class="chat-lock-icon">
                <i class="bi bi-lock-fill"></i>
            </div>
            <div class="chat-lock-text">
                <h6>Chọn môn học để bắt đầu</h6>
                <p>Vui lòng chọn <strong>Môn học</strong> ở cột bên trái để AI tìm kiếm đúng tài liệu và trả lời chính xác hơn.</p>
            </div>
        </div>

        <!-- Header status -->
        <div class="chat-header">
            <div class="chat-header-title d-flex align-items-center gap-3">
                <h5>LDS AI Assistant</h5>
                <button type="button" class="btn btn-sm btn-link text-white-50 p-0 text-decoration-none hover-white" onclick="clearChatHistory()" title="Xóa lịch sử đoạn chat" style="font-size: 0.85rem; transition: color 0.2s;">
                    <i class="bi bi-trash3 me-1"></i>Xóa lịch sử
                </button>
            </div>
            <div class="chat-header-status">
                <span class="status-dot"></span>
                <span>AI Engine Sẵn sàng</span>
            </div>
        </div>
        
        <!-- Messages list -->
        <div class="chat-messages" id="chatMessages">
            
            <!-- AI Welcome message -->
            <div class="message assistant">
                <div class="message-avatar">AI</div>
                <div class="message-content">
                    <p>Chào bạn! Tôi là Trợ lý Học tập AI (LDS AI Assistant).</p>
                    <p>Tôi đã sẵn sàng quét toàn bộ giáo trình, tệp PDF, Word, Slide bài giảng bạn đã tải lên để giải đáp mọi câu hỏi ôn tập. Hãy chọn môn học ở cột bên trái và nhập câu hỏi để bắt đầu thảo luận nhé!</p>
                </div>
            </div>
            
        </div>

        <!-- Input bottom -->
        <div class="chat-input-area">
            <form id="chatForm" onsubmit="sendChatMessage(event)">
                @Html.AntiForgeryToken()
                <div class="chat-input-wrapper">
                    <input type="text" class="chat-input" id="chatInput" 
                           placeholder="Chọn môn học trước để bắt đầu hỏi..." autocomplete="off" disabled />
                    <button type="submit" class="btn-send" id="btnSend" disabled>
                        <i class="bi bi-send-fill"></i>
                    </button>
                </div>
            </form>
        </div>
        
    </div>
</div>

<!-- Source Detail Modal -->
<div class="modal fade" id="sourceModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
            <div class="modal-header border-0 bg-light">
                <h5 class="modal-title fw-bold text-dark"><i class="bi bi-file-earmark-text-fill text-primary me-2"></i>Chi tiết đoạn trích dẫn</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body py-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="badge bg-primary fs-6" id="sourceDocTitle">Tài liệu</span>
                    <span class="badge bg-success" id="sourceScore">99% Match</span>
                </div>
                <div class="mb-3 small text-muted">
                    <i class="bi bi-file-text me-1"></i>Vị trí trích xuất: <strong id="sourcePage">Trang 1</strong>
                </div>
                <div class="p-3 bg-light border rounded text-dark" style="font-family: Inter, sans-serif; font-size: 0.95rem; line-height: 1.6; max-height: 40vh; overflow-y: auto; white-space: pre-wrap;" id="sourceText">
                    Nội dung trích dẫn...
                </div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Unique key per logged-in user to partition chat history
    const CHAT_HISTORY_KEY = 'lds_chat_history_' + '@User.Identity?.Name';

    // Auto-scroll to bottom of chat
    const messagesContainer = document.getElementById('chatMessages');
    function scrollToBottom() {
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }
    
    // Initial scroll
    scrollToBottom();

    // Toggle chat lock state
    function setChatLocked(locked) {
        const overlay = document.getElementById('chatLockOverlay');
        const input   = document.getElementById('chatInput');
        const btnSend = document.getElementById('btnSend');
        if (locked) {
            overlay.classList.remove('hidden');
            input.disabled = true;
            input.placeholder = 'Chọn môn học trước để bắt đầu hỏi...';
            btnSend.disabled = true;
        } else {
            overlay.classList.add('hidden');
            input.disabled = false;
            input.placeholder = 'Nhập câu hỏi học tập của bạn tại đây...';
            btnSend.disabled = false;
            input.focus();
        }
    }

    // Load chapters by subject
    function loadChatChapters(subjectId) {
        const select = document.getElementById('chatChapterSelect');
        select.innerHTML = '<option value="">— Đang tải... —</option>';
        select.disabled = true;
        
        if (!subjectId) {
            select.innerHTML = '<option value="">— Tất cả chương —</option>';
            setChatLocked(true);
            return;
        }

        // Unlock chat as soon as a subject is picked
        setChatLocked(false);
        
        fetch('/Document/GetChapters?subjectId=' + subjectId)
            .then(r => r.json())
            .then(data => {
                select.innerHTML = '<option value="">— Tất cả chương —</option>';
                data.forEach(c => {
                    select.innerHTML += `<option value="${c.chapterID}">Chương ${c.chapterNumber}: ${c.chapterName}</option>`;
                });
                select.disabled = false;
            });
    }

    // Reset filters
    function resetChatFilters() {
        document.getElementById('chatSubjectSelect').value = '';
        const chapterSelect = document.getElementById('chatChapterSelect');
        chapterSelect.innerHTML = '<option value="">— Tất cả chương —</option>';
        chapterSelect.value = '';
        chapterSelect.disabled = true;
        setChatLocked(true);
    }

    // Render basic markdown tags (bold and lists)
    function renderMarkdown(text) {
        // Render bold **text**
        let formatted = text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
        // Render italic *text*
        formatted = formatted.replace(/\*(.*?)\*/g, '<em>$1</em>');
        
        // Render bullet lists - lines starting with '- ' or '* '
        const lines = formatted.split('\n');
        let inList = false;
        for (let i = 0; i < lines.length; i++) {
            if (lines[i].trim().startsWith('- ')) {
                let content = lines[i].trim().substring(2);
                if (!inList) {
                    lines[i] = '<ul><li>' + content + '</li>';
                    inList = true;
                } else {
                    lines[i] = '<li>' + content + '</li>';
                }
            } else if (lines[i].trim().startsWith('>') && lines[i].trim().includes('"')) {
                // Style Blockquotes
                let quote = lines[i].trim().substring(1).replace(/"/g, '').trim();
                lines[i] = `<blockquote class="border-start border-primary border-4 ps-3 py-1 my-2 bg-light text-muted" style="font-style: italic;">"${quote}"</blockquote>`;
            } else {
                if (inList) {
                    lines[i] = '</ul>' + lines[i];
                    inList = false;
                }
            }
        }
        if (inList) {
            lines[lines.length - 1] += '</ul>';
        }
        
        return lines.join('\n').replace(/\n/g, '<br/>');
    }

    // Modal Source details popup
    function showSourceDetails(title, page, score, content) {
        document.getElementById('sourceDocTitle').textContent = title;
        document.getElementById('sourcePage').textContent = page ? 'Trang ' + page : 'Phân đoạn văn bản';
        document.getElementById('sourceScore').textContent = parseFloat(score).toFixed(1) + '% Độ tương đồng';
        document.getElementById('sourceText').textContent = content;
        new bootstrap.Modal(document.getElementById('sourceModal')).show();
    }

    // Send Chat message
    function sendChatMessage(event) {
        event.preventDefault();
        
        const input = document.getElementById('chatInput');
        const questionText = input.value.trim();
        if (!questionText) return;
        
        // Disable input during request
        input.value = '';
        input.disabled = true;
        document.getElementById('btnSend').disabled = true;
        
        // 1. Append User Message
        appendMessage('user', questionText, null, true);
        
        // 2. Append Loading Thinking Indicator
        const loadingId = appendLoadingIndicator();
        scrollToBottom();
        
        // 3. Prepare Form Data
        const formData = new FormData();
        formData.append('question', questionText);
        formData.append('subjectId', document.getElementById('chatSubjectSelect').value);
        formData.append('chapterId', document.getElementById('chatChapterSelect').value);
        
        // Anti forgery token
        const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
        if (tokenInput) {
            formData.append('__RequestVerificationToken', tokenInput.value);
        }
        
        // 4. Fetch Response via AJAX
        fetch('/Chat/Ask', {
            method: 'POST',
            body: formData
        })
        .then(r => r.json())
        .then(data => {
            // Remove loading indicator
            removeLoadingIndicator(loadingId);
            
            // 5. Append Assistant Response
            appendMessage('assistant', data.answer, data.sources, true);
            scrollToBottom();
        })
        .catch(err => {
            console.error(err);
            removeLoadingIndicator(loadingId);
            appendMessage('assistant', 'Đã xảy ra lỗi kết nối máy chủ. Bạn vui lòng tải lại trang và thử lại.', null, true);
            scrollToBottom();
        })
        .finally(() => {
            input.disabled = false;
            document.getElementById('btnSend').disabled = false;
            input.focus();
        });
    }

    // Helper: Append a message bubble to Chatbox
    function appendMessage(sender, text, sources = null, saveToStorage = true) {
        const chatMessages = document.getElementById('chatMessages');
        
        const messageDiv = document.createElement('div');
        messageDiv.className = `message ${sender}`;
        
        const avatarDiv = document.createElement('div');
        avatarDiv.className = 'message-avatar';
        avatarDiv.textContent = sender === 'user' ? 'U' : 'AI';
        
        const contentDiv = document.createElement('div');
        contentDiv.className = 'message-content';
        contentDiv.innerHTML = renderMarkdown(text);
        
        // Include Sources if present
        if (sources && sources.length > 0) {
            const sourcesDiv = document.createElement('div');
            sourcesDiv.className = 'message-sources';
            sourcesDiv.innerHTML = '<span class="text-muted d-block w-100 mb-1 small"><i class="bi bi-info-circle me-1"></i>Trích dẫn từ tài liệu học tập:</span>';
            
            // Deduplicate sources by Document Title and Page Number to avoid showing duplicate tags
            const uniqueSources = [];
            sources.forEach(src => {
                const key = `${src.documentTitle}_${src.pageNumber ?? 'N/A'}`;
                const existing = uniqueSources.find(x => `${x.documentTitle}_${x.pageNumber ?? 'N/A'}` === key);
                
                if (existing) {
                    // Concatenate snippets so clicking the tag shows both text segments beautifully
                    existing.contentSnippet += "\n\n[Đoạn trích liên quan khác từ cùng trang này]:\n" + src.contentSnippet;
                    if (src.similarityScore > existing.similarityScore) {
                        existing.similarityScore = src.similarityScore;
                    }
                } else {
                    // Deep copy the source object to avoid mutating the original array
                    uniqueSources.push({ ...src });
                }
            });

            uniqueSources.forEach(src => {
                const cleanSnippet = src.contentSnippet.replace(/'/g, "\\'").replace(/"/g, '&quot;');
                sourcesDiv.innerHTML += `
                    <div class="source-tag" onclick="showSourceDetails('${src.documentTitle}', ${src.pageNumber}, ${src.similarityScore}, '${cleanSnippet}')">
                        <i class="bi bi-file-earmark-text-fill"></i>
                        <span>${src.documentTitle.length > 35 ? src.documentTitle.substring(0, 32) + '...' : src.documentTitle}</span>
                        ${src.pageNumber ? `<span class="text-secondary small">(Tr.${src.pageNumber})</span>` : ''}
                    </div>
                `;
            });
            contentDiv.appendChild(sourcesDiv);
        }
        
        messageDiv.appendChild(avatarDiv);
        messageDiv.appendChild(contentDiv);
        chatMessages.appendChild(messageDiv);
        scrollToBottom();

        // Save to LocalStorage if requested
        if (saveToStorage) {
            let history = [];
            try {
                const existingHistory = localStorage.getItem(CHAT_HISTORY_KEY);
                if (existingHistory) {
                    history = JSON.parse(existingHistory);
                }
            } catch (e) {
                console.error("Failed to parse chat history from localStorage", e);
            }
            history.push({ sender, text, sources });
            localStorage.setItem(CHAT_HISTORY_KEY, JSON.stringify(history));
        }
    }

    // Helper: Append loading dots
    function appendLoadingIndicator() {
        const chatMessages = document.getElementById('chatMessages');
        const id = 'loading_' + Date.now();
        
        const messageDiv = document.createElement('div');
        messageDiv.className = 'message assistant';
        messageDiv.id = id;
        
        const avatarDiv = document.createElement('div');
        avatarDiv.className = 'message-avatar';
        avatarDiv.textContent = 'AI';
        
        const contentDiv = document.createElement('div');
        contentDiv.className = 'message-content';
        contentDiv.innerHTML = `
            <div class="thinking">
                <div class="dot"></div>
                <div class="dot"></div>
                <div class="dot"></div>
                <span class="text-muted small ms-2">Assistant is searching chunks...</span>
            </div>
        `;
        
        messageDiv.appendChild(avatarDiv);
        messageDiv.appendChild(contentDiv);
        chatMessages.appendChild(messageDiv);
        return id;
    }

    // Helper: Remove loading dots
    function removeLoadingIndicator(id) {
        const el = document.getElementById(id);
        if (el) el.remove();
    }

    // Load Chat History from LocalStorage
    function loadChatHistory() {
        try {
            const historyJson = localStorage.getItem(CHAT_HISTORY_KEY);
            if (historyJson) {
                const history = JSON.parse(historyJson);
                history.forEach(msg => {
                    appendMessage(msg.sender, msg.text, msg.sources, false);
                });
            }
        } catch (e) {
            console.error("Failed to load chat history", e);
        }
    }

    // Clear Chat History from LocalStorage
    function clearChatHistory() {
        if (confirm("Bạn có chắc chắn muốn xóa toàn bộ lịch sử đoạn chat này không?")) {
            localStorage.removeItem(CHAT_HISTORY_KEY);
            
            // Keep only the welcome message
            const chatMessages = document.getElementById('chatMessages');
            chatMessages.innerHTML = `
                <!-- AI Welcome message -->
                <div class="message assistant">
                    <div class="message-avatar">AI</div>
                    <div class="message-content">
                        <p>Chào bạn! Tôi là Trợ lý Học tập AI (LDS AI Assistant).</p>
                        <p>Tôi đã sẵn sàng quét toàn bộ giáo trình, tệp PDF, Word, Slide bài giảng bạn đã tải lên để giải đáp mọi câu hỏi ôn tập. Hãy chọn môn học ở cột bên trái và nhập câu hỏi để bắt đầu thảo luận nhé!</p>
                    </div>
                </div>
            `;
            scrollToBottom();
        }
    }

    // Initialize Chat History on load
    loadChatHistory();
</script>
}
