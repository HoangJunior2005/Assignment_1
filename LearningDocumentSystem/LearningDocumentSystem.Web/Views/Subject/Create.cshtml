@model LearningDocumentSystem.Web.ViewModels.SubjectFormViewModel
@{
    bool isEdit = Model.SubjectID > 0;
    ViewData["Title"] = isEdit ? "Sửa môn học" : "Thêm môn học";
}

<div class="page-header">
    <h1 class="page-title">
        <i class="bi bi-@(isEdit ? "pencil-square" : "plus-circle-fill") me-2"></i>
        @ViewData["Title"]
    </h1>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card-custom">
            <div class="card-custom-body">
                <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
                    @Html.AntiForgeryToken()
                    @if (isEdit) { <input type="hidden" asp-for="SubjectID"/> }

                    <div class="mb-4">
                        <label asp-for="SubjectName" class="form-label fw-semibold"></label>
                        <input asp-for="SubjectName" class="form-control form-control-lg"
                               placeholder="VD: Lập trình cấu trúc C#"/>
                        <span asp-validation-for="SubjectName" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="SubjectCode" class="form-label fw-semibold"></label>
                        <input asp-for="SubjectCode" class="form-control form-control-lg"
                               placeholder="VD: INF205" style="text-transform: uppercase;"
                               oninput="this.value = this.value.toUpperCase()"/>
                        <span asp-validation-for="SubjectCode" class="text-danger small"></span>
                        <div class="form-text">Chỉ gồm chữ hoa và số (VD: INF205, CS101)</div>
                    </div>

                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-@(isEdit ? "save" : "plus-circle") me-1"></i>
                            @(isEdit ? "Cập nhật" : "Tạo môn học")
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
